    "@typescript/native-preview": "latest",
    "oxfmt": "^0.49.0",
    "oxlint": "^1.64.0",
    "svelte": "^5.55.5",
    "svelte-check": "^4.4.8",
    "unocss": "^66.6.8",
    "vite": "^8.0.12"
  },
  "packageManager": "bun@1.3.14"
